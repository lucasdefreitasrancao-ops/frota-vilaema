rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /caminhoes/{docId} {
      allow read, write: if request.auth != null;
    }
    match /manutencoes/{docId} {
      allow read, write: if request.auth != null;
    }
    match /trocas_pneus/{docId} {
      allow read, write: if request.auth != null;
    }
    match /checklists/{docId} {
      allow read, write: if request.auth != null;
    }
    match /multas/{docId} {
      allow read, write: if request.auth != null;
    }
    match /lavagens_frota/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
